generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model tbl_doce {
  id_doce                Int                      @id @default(autoincrement())
  tipo                   String                   @db.VarChar(120)
  nome                   String                   @db.VarChar(120)
  massa                  String                   @db.VarChar(120)
  recheio                String                   @db.VarChar(120)
  cobertura              String                   @db.VarChar(120)
  qtd                    Int
  peso                   Decimal                  @db.Decimal(10, 2)
  porcao                 Int
  preco                  Decimal                  @db.Decimal(10, 2)
  data_criacao           DateTime                 @default(dbgenerated("(curdate())")) @db.DateTime(0)
  data_validade          DateTime                 @db.Date
  status                 tbl_doce_status
  tbl_historico_descarte tbl_historico_descarte[]
}

model tbl_funcionario {
  id_funcionario         Int                      @id @default(autoincrement())
  nome                   String                   @db.VarChar(120)
  email                  String                   @db.VarChar(120)
  senha                  String                   @db.VarChar(100)
  tbl_historico_descarte tbl_historico_descarte[]
}

model tbl_historico_descarte {
  id_historico_descarte Int             @id @default(autoincrement())
  id_doce               Int
  id_funcionario        Int
  data_descarte         DateTime        @default(dbgenerated("(curdate())")) @db.DateTime(0)
  tbl_doce              tbl_doce        @relation(fields: [id_doce], references: [id_doce], onDelete: NoAction, onUpdate: NoAction, map: "fk_doce_descarte")
  tbl_funcionario       tbl_funcionario @relation(fields: [id_funcionario], references: [id_funcionario], onDelete: NoAction, onUpdate: NoAction, map: "fk_funcionario_descarte")

  @@index([id_doce], map: "fk_doce_descarte")
  @@index([id_funcionario], map: "fk_funcionario_descarte")
}

enum tbl_doce_status {
  Disponivel
  Descartado
}
